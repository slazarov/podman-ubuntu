#!/bin/bash

# v5 track version POLICY — Podman 5.x maintenance line (auto-updating).
#
# Same machinery as versions-stable.env (resolved by scripts/resolve_versions.sh);
# only the coupled-core series differ. This file is a policy of `export` statements
# with no logic. See versions-stable.env for the full precedence documentation.
#
# WHY a separate 5.x track: netavark/aardvark-dns 2.0 + buildah 1.44 broke
# compatibility and are "only supported with podman 6.0" (netavark 2.0.0
# RELEASE_NOTES). Podman 5.x must stay on netavark/aardvark 1.x + buildah 1.43.x.
export STABLE_SOAK_DAYS="3"

# --- Coupled container core: held on the podman-5.x-compatible majors ---
export PODMAN_SERIES="5"
export NETAVARK_SERIES="1"
export AARDVARK_DNS_SERIES="1"

# buildah derived from podman 5.x's go.mod (= v1.43.2 for podman 5.8.x). BUILDAH_SERIES
# both caps the fallback and clamps the derived value, keeping buildah on 1.43.x even
# if a podman patch ever pinned a newer buildah.
export BUILDAH_SERIES="1.43"

# --- Leaf / loosely-coupled tools: float to the latest soaked tag ---
# crun, conmon, skopeo, container-configs, go-md2man, toolbox, fuse-overlayfs,
# catatonit are ABI-stable / standalone and shared with the stable track.
#
# container-configs (CONTAINER_LIBS_TAG, containers.conf/policy.json/seccomp
# defaults) is deliberately SHARED with the 6.x stable track, NOT capped to a 5.x
# era. Rationale: these config files are forward-compatible on a Podman 5.x runtime
# — containers.conf keys the older runtime does not know are only warned about and
# ignored (never a hard failure), and the default policy.json / seccomp profiles are
# schema-stable and forward-compatible. A true era-exact cap is impossible anyway:
# the containers/container-libs monorepo we build from only carries common/v0.66-0.68
# tags; the Podman-5.8-era set (containers/common 0.62-0.64) lives in the ARCHIVED
# containers/common repo, which this pipeline does not build. So no CONTAINER_LIBS_SERIES.

# --- Build tools: exact pins (toolchain, not upstream components) ---
export PROTOC_VERSION="34.0"
export PROTOC_TAG="v34.0"
