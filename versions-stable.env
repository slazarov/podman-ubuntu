#!/bin/bash

# Stable build track - pinned component versions
# Source this file before setup.sh to build stable releases
# Update these when promoting new versions to stable
#
# Usage: source versions-stable.env && ./setup.sh
#
# These override the empty defaults in config.sh via
# the ${VAR:-} pattern used there.

export SCCACHE_TAG="v0.15.0"
export PODMAN_TAG="v6.0.0"
export BUILDAH_TAG="v1.44.0"
export CRUN_TAG="1.28"
export CONMON_TAG="v2.2.1"
export NETAVARK_TAG="v2.0.0"
export AARDVARK_DNS_TAG="v2.0.0"
export SKOPEO_TAG="v1.23.0"
export GOMD2MAN_TAG="v2.0.7"
export TOOLBOX_TAG="0.3"
export FUSE_OVERLAYFS_TAG="v1.16"
export CATATONIT_TAG="v0.2.1"
export CONTAINER_LIBS_TAG="common/v0.68.0"
export PROTOC_VERSION="34.0"
export PROTOC_TAG="v34.0"
