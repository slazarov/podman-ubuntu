#!/bin/bash

# Stable track version POLICY — Podman 6.x line (auto-updating).
#
# This file is a *policy*, not a manifest: it declares how each component's version
# is chosen, and scripts/resolve_versions.sh materializes the concrete `*_TAG`s from
# it. It contains only `export` statements — no logic.
#
# Resolution precedence per component (see scripts/resolve_versions.sh):
#   1. <C>_TAG    — exact freeze (escape hatch), bypasses soak. Set one to pin.
#   2. buildah    — derived from podman's go.mod at the resolved PODMAN_TAG.
#   3. <C>_SERIES — highest tag in that anchored series (e.g. "6" -> 6.x), soaked.
#   4. neither    — float to the highest soaked stable tag.
#
# STABLE_SOAK_DAYS: a non-frozen/non-derived tag is only adopted once it is at least
# this many days old, so a same-day botched upstream release is never picked up.
export STABLE_SOAK_DAYS="3"

# --- Coupled container core: series-capped at the major (float minor+patch) ---
# netavark/aardvark-dns 2.x + buildah 1.44 are the set "only supported with podman
# 6.0" (netavark 2.0.0 RELEASE_NOTES) — keep these on the 6.x-compatible majors.
# Bump a SERIES only to move the whole stack to a new major.
export PODMAN_SERIES="6"
export NETAVARK_SERIES="2"
export AARDVARK_DNS_SERIES="2"

# buildah is normally derived from podman's go.mod (the blessed pairing). BUILDAH_SERIES
# both (a) caps the fallback when that derivation can't be fetched and (b) clamps the
# derived value — a derived buildah outside this series is rejected in favour of the
# cap — so buildah can never cross the 6.x compatibility boundary.
export BUILDAH_SERIES="1.44"

# --- Leaf / loosely-coupled tools: float to the latest soaked tag ---
# crun, conmon, skopeo, container-configs (and go-md2man, toolbox, fuse-overlayfs,
# catatonit) have no *_SERIES here, so they float. They are ABI-stable / standalone
# and shared with the v5 track. Pin one with its *_TAG to freeze it if ever needed.

# --- Build tools: exact pins (toolchain, not upstream components) ---
export PROTOC_VERSION="34.0"
export PROTOC_TAG="v34.0"
