#!/bin/bash

# Nightly build track - build from latest upstream commits (HEAD)
# Source this file before setup.sh to build nightly snapshots
#
# When NIGHTLY_BUILD=true:
#   - git_checkout() stays on the default branch HEAD instead of checking out a tag
#   - package_all.sh extracts dev versions from source files (e.g., 5.9.0~git20260306.abc1234)
#   - Nightly versions use tilde (~) to sort BELOW tagged releases via dpkg,
#     so users auto-upgrade when a real release lands
#
# SHALLOW_CLONE=false is required for git describe support (commit history needed)
#
# Usage: source versions-nightly.env && ./setup.sh
#
# No TAG variables are set here - all remain empty so config.sh defaults apply.
# git_checkout() sees no tag and stays on HEAD when NIGHTLY_BUILD=true.

export NIGHTLY_BUILD="true"
export SHALLOW_CLONE="false"
